# Másold .env-be és töltsd ki. A .env SOHA nem megy gitbe.
# --- DB / queue ---
DATABASE_URL=postgresql+asyncpg://cx:cx@postgres:5432/cx
REDIS_URL=redis://redis:6379/0

# --- Qdrant (lokális dev konténer, NEM az éles!) ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=cx_chatbot

# --- LLM / embedding ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
CHAT_MODEL=claude-haiku-4-5-20251001
EMBED_MODEL=text-embedding-3-small

# --- admin ---
ADMIN_TOKEN=dev

# --- retrieval hangolás (opcionális, van default) ---
RETRIEVAL_TOP_K=30
CONTEXT_TOP_N=8
